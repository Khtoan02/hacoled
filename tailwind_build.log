      '.hdr-hotline-cskh:hover .hdr-hotline-number  { color: #fbbf24; }\n' +
      '.hdr-hotline-sales:hover .hdr-hotline-number { color: #fff; }\n' +
      '\n' +
      '/* Ping ring for hotline */\n' +
      '@keyframes hdr-ping {\n' +
      '  0%   { transform: scale(1); opacity: 0.7; }\n' +
      '  75%, 100% { transform: scale(2); opacity: 0; }\n' +
      '}\n' +
      '.hdr-ping { animation: hdr-ping 1.8s ease-out infinite; }\n' +
      '\n' +
      '/* ─── BOTTOM NAV ────────────────────────────────────────────────── */\n' +
      '#hdr-nav {\n' +
      '  display: none;                /* Hidden on mobile – shown lg+ */\n' +
