      '}\n' +
      '.hdr-search form:focus-within .hdr-search-icon { color: #fbbf24; }\n' +
      '\n' +
      '/* ─── HOTLINE blocks ────────────────────────────────────────────── */\n' +
      '.hdr-hotline {\n' +
      '  display: flex; align-items: center; gap: 12px;\n' +
