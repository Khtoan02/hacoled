      '   · Full-width panels anchored to <nav> left/right edges\n' +
      '   ================================================================ */\n' +
      '\n' +
      '/* ─── TOP BAR subtle grid ─────────────────────────────────────── */\n' +
      '.hdr-top-bg {\n' +
      '  position: absolute; inset: 0; pointer-events: none; z-index: 0;\n' +
      '  background-image:\n' +
      '    linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),\n' +
      '    linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);\n' +
      '  background-size: 44px 44px;\n' +
      '}\n' +
      '\n' +
      '/* ─── LOGO: Trống Đồng centered BEHIND logo image ────────────── */\n' +
      '/*\n' +
      '  Structure:\n' +
      '    <div class="hdr-logo">          ← 160×64px positioned container\n' +
      '      <div class="hdr-logo-ds"></div> ← 140×140 stamp, abs-centered\n' +
      '      <a class="hdr-logo-link">     ← z:10, on top of stamp\n' +
      '        <img>\n' +
      '      </a>\n' +
      '    </div>\n' +
      '*/\n' +
      '.hdr-logo {\n' +
      '  position: relative;\n' +
      '  flex-shrink: 0;\n' +
      '  display: flex;\n' +
      '  align-items: center;\n' +
      '  justify-content: flex-start;\n' +
      '  height: 80px;\n' +
      '}\n' +
      '.hdr-logo-ds {\n' +
      '  position: absolute;\n' +
      '  top: 50%;\n' +
      '  left: 50%;\n' +
      '  transform: translate(-50%, -50%);\n' +
      '  width: 420px;\n' +
      '  height: 420px;\n' +
      "  background-image: url('https://upload.wikimedia.org/wikipedia/commons/thumb/1/16/Tr%E1%BB%91ng_%C4%91%E1%BB%93ng_%C4%90%C3%B4ng_S%C6%A1n.svg/960px-Tr%E1%BB%91ng_%C4%91%E1%BB%93ng_%C4%90%C3%B4ng_S%C6%A1n.svg.png');\n" +
      '  background-repeat: no-repeat;\n' +
      '  background-position: center;\n' +
      '  background-size: contain;\n' +
      '  opacity: 0.12;\n' +
      '  pointer-events: none;\n' +
      '  filter: invert(1);\n' +
      '  z-index: 0;\n' +
      '  transition: opacity 0.35s ease;\n' +
      '}\n' +
      '.hdr-logo:hover .hdr-logo-ds { opacity: 0.16; }\n' +
      '.hdr-logo-link {\n' +
      '  position: relative;\n' +
      '  z-index: 10;\n' +
      '  display: flex;\n' +
      '  align-items: center;\n' +
      '}\n' +
      '.hdr-logo-link img {\n' +
      '  height: 72px;\n' +
      '  width: auto;\n' +
      '  object-fit: contain;\n' +
      '  transition: opacity 0.2s;\n' +
      '}\n' +
      '.hdr-logo-link:hover img { opacity: 0.88; }\n' +
      '\n' +
      '/* Scrolled state: smaller logo */\n' +
      '.site-header.is-scrolled .hdr-logo { height: 60px; width: 150px; }\n' +
      '.site-header.is-scrolled .hdr-logo-ds { width: 240px; height: 240px; }\n' +
      '.site-header.is-scrolled .hdr-logo-link img { height: 44px; }\n' +
      '\n' +
      '/* ─── SEARCH INPUT ─────────────────────────────────────────────── */\n' +
      '.hdr-search {\n' +
      '  flex: 1;\n' +
      '  max-width: 480px;\n' +
      '}\n' +
      '.hdr-search form { position: relative; }\n' +
      '.hdr-search input {\n' +
      '  width: 100%;\n' +
      '  padding: 10px 18px 10px 44px;\n' +
      '  border-radius: 50px;\n' +
      '  background: rgba(0,0,0,0.28);\n' +
      '  border: 1px solid rgba(255,255,255,0.12);\n' +
      '  color: #fff;\n' +
      '  font-size: 13px;\n' +
      '  font-family: inherit;\n' +
      '  outline: none;\n' +
      '  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;\n' +
      '}\n' +
      '.hdr-search input::placeholder { color: rgba(148,163,184,0.7); }\n' +
      '.hdr-search input:focus {\n' +
      '  border-color: rgba(251,191,36,0.55);\n' +
